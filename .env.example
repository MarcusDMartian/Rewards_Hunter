# ============================================
# Reward Hunter - Frontend Environment Variables
# ============================================
# Copy this file to .env (development) or set in Vercel dashboard (production)

# API base URL — your deployed backend (Render / Railway / Fly)
# Must include the /api prefix.
VITE_API_URL=http://localhost:3000/api

# Toggle: when true the app skips real API calls (debug-only, default false)
VITE_USE_MOCK_DATA=false

# App environment label (used by monitoring tools)
VITE_APP_ENV=development

# Sentry DSN for frontend error tracking (optional)
VITE_SENTRY_DSN=
