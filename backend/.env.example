# ============================================
# Reward Hunter - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# Runtime
NODE_ENV=development              # production | development | test
PORT=3000

# Database (MongoDB Atlas connection string)
DATABASE_URL="mongodb+srv://<user>:<password>@cluster.mongodb.net/reward-hunter"

# JWT (REQUIRED in production — must be >=32 chars)
# Generate a strong value:  openssl rand -base64 64
JWT_SECRET="change-me-to-a-random-64-char-string"
JWT_EXPIRES_IN=24h

# Email — OPTION 1 (recommended): Brevo SMTP — free 300 emails/day, works on all cloud providers
# Sign up at https://app.brevo.com → SMTP & API → Generate SMTP key
# BREVO_SMTP_USER: your Brevo login email
# BREVO_SMTP_KEY: the generated SMTP key (starts with "xsmtp...")
BREVO_SMTP_USER="your-brevo-login@email.com"
BREVO_SMTP_KEY="xsmtp-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Email — OPTION 2 (fallback): Gmail SMTP (may be blocked by some cloud providers)
# GMAIL_APP_PASSWORD must be a 16-char App Password (NOT your Gmail login password).
# Create one at: https://myaccount.google.com/apppasswords (requires 2-Step Verification)
GMAIL_USER="your.account@gmail.com"
GMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# CORS — comma-separated origins allowed to call the API
# Example: https://rewardshunter.vercel.app,https://rewardhunter.com
CORS_ORIGINS="http://localhost:5173"

# Observability (optional)
SENTRY_DSN=""
LOG_LEVEL=info
